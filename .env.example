# Aiven MySQL — copy to .env.local and fill in values (never commit .env.local)

DB_HOST=your-service.aivencloud.com
DB_PORT=12345
DB_NAME=defaultdb
DB_USER=avnadmin
DB_PASSWORD=

# Secret used to sign auth session cookies. Set this in Vercel, too.
AUTH_SECRET=change-me-to-a-long-random-string

# Set to true for Aiven (TLS required)
DB_SSL=true

# Paste the full PEM from Aiven "CA certificate" (multiline OK in .env.local)
# Or use a single-line base64-encoded PEM:
# DB_CA_BASE64=

# Optional explicit CA (alternative to DB_CA): path on local machine only — not for Vercel
# DB_CA_PATH=./ca.pem

# Dev-only fallback if CA is missing: set to true to disable cert verification (NOT for production)
# DB_SSL_INSECURE=false
